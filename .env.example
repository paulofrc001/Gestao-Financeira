# 1. GEMINI: Required for AI analysis (Insights, Chat, Parsing)
# This is automatically set in AI Studio, but needed for external deployments.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# 2. SUPABASE: Required for Database and Auth.
# Go to Supabase Project Settings -> API to find these.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# 3. APP: Optional
APP_URL="https://your-app.vercel.app"
